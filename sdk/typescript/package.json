{
  "name": "@hermem/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Hermem API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": ["hermem", "memory", "graph", "llm", "agent"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.10"
  }
}
