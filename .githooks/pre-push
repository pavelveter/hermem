#!/usr/bin/env bash
#
# .githooks/pre-push — project-wide pre-push hook (versioned).
#
# To enable on a fresh clone:
#   git config core.hooksPath .githooks
# Or check it in via a `Makefile` / `install.sh` setup step.
#
# What it runs (in order):
#   1.  Architecture guardrails (grep)        — ci.yml `guardrails` job
#   2.  gofmt -l (no diffs required)          — fast format check
#   3.  go vet ./src/...                      — fast
#   4.  go build ./src/...                    — fast
#   5.  go test -race -count=1 -timeout 10m   — slow (mirrors ci.yml `test` job)
#   6.  E2E tests (CLI + HTTP + scenarios)     — builds binary, runs all e2e
#   7.  Fuzz tests (10s each)                  — mirrors ci.yml `fuzz` job
#   8.  govulncheck (optional, if installed)   — mirrors ci.yml `govulncheck` job
#   9.  OpenAPI validation tests               — mirrors ci.yml `openapi` job
#   10. golangci-lint (optional, if installed)  — mirrors ci.yml `lint` job
#   11. AMX guard (optional, darwin + CGO)      — mirrors ci-amx.yml
#   12. API compatibility (optional, if tags)   — mirrors ci.yml `apidiff` job
#   13. gitleaks secrets scan (optional)         — mirrors ci.yml `gitleaks` job
#   14. gosec security scan (optional)           — mirrors ci.yml `gosec` job
#
# NOT mirrored: ci.yml `build` matrix cross-platform zig builds
# (linux/amd64, linux/arm64, windows/amd64, windows/arm64). 4 cross-
# compiles per push would take 10+ minutes; run them locally only
# when actually targeting a foreign matrix.
#
# Bypass: `git push --no-verify` skips the hook entirely.
# Failure: any non-zero exit blocks the hook.
set -euo pipefail

# Color output (TTY-aware so CI logs stay readable).
if [ -t 1 ]; then
    RED=$'\033[31m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'; CYAN=$'\033[36m'; RESET=$'\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; CYAN=''; RESET=''
fi

section() { printf "\n${CYAN}==> %s${RESET}\n" "$1"; }
ok()      { printf "${GREEN}✓${RESET} %s\n" "$1"; }
fail()    { printf "${RED}✗${RESET} %s\n" "$1" >&2; exit 1; }
warn()    { printf "${YELLOW}!${RESET} %s\n" "$1"; }

# Drain hook stdin (git pipes `<local_ref> <local_oid> <remote_ref> <remote_oid>`).
# Reading is not required for any of our checks, so just discard.
cat > /dev/null

# 1. Architecture guardrails — mirrors `ci.yml > guardrails` job.
section "Architecture guardrails"
if grep -rn 'ActiveSchema()' src/ --include='*.go' 2>/dev/null; then
    fail "ActiveSchema() usage detected (removed — use DI via Env / Service constructor)"
fi
if grep -rn 'var RequiredScopes' src/ --include='*.go' 2>/dev/null; then
    fail "Exported mutable state violation: var RequiredScopes must remain unexported"
fi
ok "Architecture guardrails (ActiveSchema, exported mutable state)"

# 2. gofmt — list any files needing format; non-zero if any.
section "gofmt"
unformatted=$(gofmt -l src/ 2>/dev/null || true)
if [ -n "$unformatted" ]; then
    printf "%s\n" "$unformatted" >&2
    fail "gofmt: files need formatting (run: gofmt -w src/)"
fi
ok "gofmt"

# 3. go vet.
section "go vet ./src/..."
go vet ./src/...
ok "go vet"

# 4. go build — create placeholder files if bin/ is missing so go:embed succeeds.
section "go build ./src/..."
BIN_DIR="src/internal/ai/bin"
if [ ! -d "$BIN_DIR" ]; then
    warn "bin/ not found — creating placeholder for go:embed"
    scripts/ensure-embed-placeholders.sh
fi
go build -o hermem ./src
ok "go build"

# 5. Race tests — slow gate. Mirrors ci.yml `test` job exactly.
section "go test -race -count=1 -timeout 10m ./src/... (this may take several minutes)"
go test -race -count=1 -timeout 10m ./src/...
ok "go test -race ./src/..."

# 6. E2E tests — builds binary, runs CLI + HTTP + scenario tests.
section "go test -p 1 -timeout 5m ./tests/e2e/... (E2E tests)"
go test -p 1 -timeout 5m ./tests/e2e/...
ok "go test -p 1 ./tests/e2e/... (E2E)"

# 7. Fuzz tests — short 10s runs per target. Mirrors ci.yml `fuzz` job.
section "Fuzz tests (10s each)"
go test -fuzz=FuzzSplitSQL -fuzztime=10s ./src/internal/store/... 2>&1 && ok "Fuzz FuzzSplitSQL" || warn "Fuzz FuzzSplitSQL skipped or failed"
go test -fuzz=FuzzCosineSimilarity -fuzztime=10s ./src/internal/vector/... 2>&1 && ok "Fuzz FuzzCosineSimilarity" || warn "Fuzz FuzzCosineSimilarity skipped or failed"
go test -fuzz=FuzzEntityJSONRoundTrip -fuzztime=10s ./src/internal/core/... 2>&1 && ok "Fuzz FuzzEntityJSONRoundTrip" || warn "Fuzz FuzzEntityJSONRoundTrip skipped or failed"
go test -fuzz=FuzzStoreRequestJSONRoundTrip -fuzztime=10s ./src/internal/core/... 2>&1 && ok "Fuzz FuzzStoreRequestJSONRoundTrip" || warn "Fuzz FuzzStoreRequestJSONRoundTrip skipped or failed"

# 8. govulncheck — only if installed locally. CI installs it.
if command -v govulncheck >/dev/null 2>&1; then
    section "govulncheck ./src/..."
    govulncheck ./src/...
    ok "govulncheck"
else
    warn "govulncheck not installed — skipping (CI installs it; install: go install golang.org/x/vuln/cmd/govulncheck@latest)"
fi

# 9. OpenAPI validation — mirrors ci.yml `openapi` job.
section "OpenAPI validation tests"
go test -run 'Test(Spec|Paths|Schemas|Operation|Snapshot|Every)' ./api/... 2>&1 && ok "OpenAPI validation" || warn "OpenAPI validation skipped or failed"

# 10. golangci-lint — only if installed locally. CI uses v2.12.2.
if command -v golangci-lint >/dev/null 2>&1; then
    section "golangci-lint run ./src/..."
    golangci-lint run --timeout=5m ./src/...
    ok "golangci-lint"
else
    warn "golangci-lint not installed — skipping (CI uses v2.12.2; install: brew install golangci-lint)"
fi

# 11. AMX guard — only on Darwin with CGO_ENABLED=1 (mirrors ci-amx.yml).
if [ "$(uname -s 2>/dev/null)" = "Darwin" ] \
    && command -v go >/dev/null 2>&1 \
    && [ "$(go env CGO_ENABLED 2>/dev/null)" = "1" ]; then
    section "AMX guard (TestBatchDot_AMXGuard)"
    go test -run TestBatchDot_AMXGuard -count=1 ./src/internal/vector/...
    ok "AMX guard"
else
    warn "AMX guard skipped (requires darwin + go on PATH + go env CGO_ENABLED=1)"
fi

# 12. API compatibility — only if go-apidiff installed and tags exist.
if command -v go-apidiff >/dev/null 2>&1; then
    LATEST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "")
    if [ -n "$LATEST_TAG" ]; then
        section "API compatibility (vs $LATEST_TAG)"
        go-apidiff "$LATEST_TAG" --print-compatible
        ok "API compatibility"
    else
        warn "No git tags found — skipping API compatibility check"
    fi
else
    warn "go-apidiff not installed — skipping (install: go install github.com/jimmidyson/go-apidiff@latest)"
fi

# 13. gitleaks — secrets scan. Only if installed locally.
if command -v gitleaks >/dev/null 2>&1; then
    section "gitleaks detect (secrets scan)"
    gitleaks detect --source . --verbose 2>&1
    ok "gitleaks"
else
    warn "gitleaks not installed — skipping (install: brew install gitleaks)"
fi

# 14. gosec — static security analysis. Only if installed locally.
if command -v gosec >/dev/null 2>&1; then
    section "gosec ./src/... (security scan)"
    gosec -exclude-generated -exclude-dir=tests ./src/...
    ok "gosec"
else
    warn "gosec not installed — skipping (install: go install github.com/securego/gosec/v2/cmd/gosec@latest)"
fi

printf "\n${GREEN}==> All pre-push checks passed. Pushing.${RESET}\n"
