{
  "name": "hermem",
  "image": "mcr.microsoft.com/devcontainers/go:1.26",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "go mod download && go install golang.org/x/perf/cmd/benchstat@latest && go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "golangci-lint.golangci-lint",
        "ms-vscode.go"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.lintTool": "golangci-lint",
        "editor.formatOnSave": true
      }
    }
  },
  "forwardPorts": [8420]
}
